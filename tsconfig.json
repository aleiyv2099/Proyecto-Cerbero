{
    "compilerOptions": {
      "lib": ["ES2020"],
      "target": "ES2020",
      "module": "commonjs",
      "moduleResolution": "node",
      "outDir": "./dist",
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "skipLibCheck": true,
      "sourceMap": true,
      "strict": true,
      "forceConsistentCasingInFileNames": true
    }
  }
